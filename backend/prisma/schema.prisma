generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int          @id @default(autoincrement())
  username   String       @unique @db.VarChar(255)
  name       String       @db.VarChar(255)
  email      String       @unique @db.VarChar(255)
  password   String       @db.VarChar(255)
  token      String?      @unique @db.VarChar(255)
  createdAt  DateTime     @default(now())
  userKanjis UserKanji[]
  userKotoba UserKotoba[]

  @@map("users")
}

enum JlptLevel {
  N5
  N4
  N3
  N2
  N1
}

model Kanji {
  id          String        @id @default(uuid())
  character   String        @unique @db.VarChar(10)
  jlptLevel   JlptLevel
  onyomi      String        @db.VarChar(255)
  kunyomi     String        @db.VarChar(255)
  meaning     String        @db.VarChar(500)
  strokeCount Int?
  radical     String?       @db.VarChar(10)
  createdAt   DateTime      @default(now())
  userKanjis  UserKanji[]
  kanjiKotoba KanjiKotoba[]

  @@map("kanjis")
}

model UserKanji {
  id           String    @id @default(uuid())
  userId       Int
  kanjiId      String
  isMemorized  Boolean   @default(false)
  reviewCount  Int       @default(0)
  difficulty   Int?
  note         String?   @db.Text
  lastReviewed DateTime?
  memorizedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  kanji Kanji @relation(fields: [kanjiId], references: [id], onDelete: Cascade)

  @@unique([userId, kanjiId])
  @@map("user_kanji")
}

model Kotoba {
  id        String     @id @default(uuid())
  word      String     @db.VarChar(100) // 食べる
  reading   String     @db.VarChar(100) // たべる
  meaning   String     @db.VarChar(500) // makan
  jlptLevel JlptLevel?
  createdAt DateTime   @default(now())

  kanjiKotoba KanjiKotoba[]
  userKotoba  UserKotoba[]

  @@map("kotoba")
}

model KanjiKotoba {
  kanjiId  String
  kotobaId String

  kanji  Kanji  @relation(fields: [kanjiId], references: [id], onDelete: Cascade)
  kotoba Kotoba @relation(fields: [kotobaId], references: [id], onDelete: Cascade)

  @@id([kanjiId, kotobaId])
  @@map("kanji_kotoba")
}

model UserKotoba {
  id           String    @id @default(uuid())
  userId       Int
  kotobaId     String
  isMemorized  Boolean   @default(false)
  reviewCount  Int       @default(0)
  difficulty   Int?
  note         String?   @db.Text
  lastReviewed DateTime?
  memorizedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  kotoba Kotoba @relation(fields: [kotobaId], references: [id], onDelete: Cascade)

  @@unique([userId, kotobaId])
  @@map("user_kotoba")
}
